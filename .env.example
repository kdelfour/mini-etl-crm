# Copier en `.env` au besoin. Les valeurs par défaut suffisent en local
# (elles correspondent au docker-compose). Ports décalés pour coexister
# avec un monolith-back déjà lancé (5432/5672/6379 souvent pris).

# Base PostgreSQL
SQL_USER=etl
SQL_PASSWORD=etl
SQL_HOST=localhost
SQL_PORT=5440
SQL_DATABASE=crm_etl

# RabbitMQ (broker Celery)
RABBITMQ_USER=etl
RABBITMQ_PASSWORD=etl
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5673
RABBITMQ_VHOST=/

# Redis (cache / disponible si besoin)
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_DB=0
